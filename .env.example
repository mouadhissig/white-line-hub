# SMTP Configuration for Netlify Function
# These environment variables must be configured in Netlify dashboard
# under Site settings > Environment variables
#
# For Zoho Mail SMTP settings:

SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@whitelineissig.me
SMTP_PASS=your-zoho-password-here

# Google Apps Script webhook URL for survey submissions
# Deployed web-app URL from Google Apps Script project
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
